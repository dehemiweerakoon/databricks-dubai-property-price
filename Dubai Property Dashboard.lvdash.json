{
  "datasets": [
    {
      "name": "monthly_transactions",
      "displayName": "Monthly Transaction Trends",
      "config": {
        "version": "1.1",
        "source": "SELECT \n  DATE_FORMAT(instance_date, 'yyyy-MM') AS year_month,\n  instance_date,\n  trans_value\nFROM workspace.default.silver_dubai_property WHERE instance_date IS NOT NULL \n  AND trans_value IS NOT NULL\n",
        "dimensions": [
          {
            "name": "year_month",
            "expr": "year_month"
          },
          {
            "name": "instance_date",
            "expr": "instance_date"
          }
        ],
        "measures": [
          {
            "name": "total_transaction_value",
            "expr": "SUM(trans_value)",
            "displayName": "Total Transaction Value"
          },
          {
            "name": "transaction_count",
            "expr": "COUNT(*)",
            "displayName": "Number of Transactions"
          },
          {
            "name": "avg_transaction_value",
            "expr": "AVG(trans_value)",
            "displayName": "Average Transaction Value"
          }
        ]
      }
    },
    {
      "name": "top_areas",
      "displayName": "Top Areas by Transaction Count",
      "queryLines": [
        "SELECT\n",
        "  area_en,\n",
        "  count_trans_value,\n",
        "  avg_price_per_sqm\n",
        "FROM\n",
        "  gold_price_by_area\n",
        "ORDER BY\n",
        "  count_trans_value DESC\n",
        "LIMIT 20"
      ],
      "catalog": "workspace",
      "schema": "default"
    },
    {
      "name": "price_by_property_type",
      "displayName": "Price by Property Type",
      "queryLines": [
        "SELECT\n",
        "  prop_sb_type_en,\n",
        "  AVG(avg_price_per_sqm) as avg_price_per_sqm\n",
        "FROM\n",
        "  gold_price_by_type\n",
        "WHERE\n",
        "  prop_sb_type_en IS NOT NULL\n",
        "GROUP BY\n",
        "  prop_sb_type_en\n",
        "ORDER BY\n",
        "  avg_price_per_sqm DESC"
      ],
      "catalog": "workspace",
      "schema": "default"
    },
    {
      "name": "property_type_value_share",
      "displayName": "Property Type Market Share by Value",
      "queryLines": [
        "SELECT\n",
        "  prop_sb_type_en,\n",
        "  SUM(trans_value) as total_value\n",
        "FROM\n",
        "  silver_dubai_property\n",
        "WHERE\n",
        "  prop_sb_type_en IS NOT NULL\n",
        "  AND trans_value IS NOT NULL\n",
        "GROUP BY\n",
        "  prop_sb_type_en\n",
        "ORDER BY\n",
        "  total_value DESC"
      ],
      "catalog": "workspace",
      "schema": "default"
    }
  ],
  "pages": [
